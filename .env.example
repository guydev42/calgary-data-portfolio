# Calgary Open Data Portfolio — Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and will NOT be committed.

# Socrata Open Data API app token (optional but recommended)
# Without a token, API requests are rate-limited to ~1000/hour.
# Get a free token at: https://data.calgary.ca/profile/edit/developer_settings
SOCRATA_APP_TOKEN=
